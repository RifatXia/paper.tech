# paper.tech — Environment Variables
# Copy to .env and fill in real values

# Supermemory
SUPERMEMORY_KEY=

# Actian VectorAI DB
ACTIAN_DB_URL=

# Modal (serverless GPU)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_LLM_ENDPOINT=
MODAL_EMBED_ENDPOINT=

# OpenAlex (data source)
OPENALEX_EMAIL=

# App config
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development

# Frontend (Vite exposes VITE_* vars to the browser)
# Leave empty in dev (Vite proxy handles /api). Set in production.
VITE_API_URL=
